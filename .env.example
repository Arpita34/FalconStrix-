# Copy to .env and adjust. python-dotenv loads this from the repo root.

# --- MySQL / MariaDB (Windows + Kali) ---
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=hidrs
MYSQL_PASSWORD=hidrs_secret
MYSQL_DATABASE=hidrs_db

# --- Event / IPC paths (optional) ---
# Leave all HIDRS_* lines commented or omitted for automatic defaults:
#   Kali/Linux: /tmp/hidrs_*.fifo (named pipes; matches hidrs_os_engine C++ defaults)
#   Windows:    <repo>/var/hidrs_events.jsonl and hidrs_cmd.jsonl (file mode; no mkfifo)
# Do not use /tmp/... on Windows in .env (that maps to C:\tmp\...). Comment these out on Windows.
#
# Uncomment to pin explicit paths. Relative paths are resolved from the repo root.

# Kali — FIFOs (recommended when running hidrs_os_engine):
# HIDRS_EVENTS_FIFO=/tmp/hidrs_events.fifo
# HIDRS_CMD_FIFO=/tmp/hidrs_cmd.fifo
# HIDRS_AUTH_SIM_LOG=/tmp/hidrs_sim_auth.log
# HIDRS_WATCH_FILE=/tmp/hidrs_watch_file.txt

# Windows — repo var/ (optional; same as auto-defaults on Windows):
# HIDRS_EVENTS_FIFO=var/hidrs_events.jsonl
# HIDRS_CMD_FIFO=var/hidrs_cmd.jsonl
# HIDRS_AUTH_SIM_LOG=var/hidrs_sim_auth.log
# HIDRS_WATCH_FILE=var/hidrs_watch_file.txt

# FSM tuning (optional)
FSM_WINDOW_SEC=120
FSM_WARN_THRESHOLD=4
FSM_LOCK_THRESHOLD=10
FSM_LOCK_HIGH_ALERTS=3

DASHBOARD_PORT=5000
