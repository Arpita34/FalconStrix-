# Copy to .env in this folder (same directory as requirements.txt).
# gui_dashboard/app.py loads it automatically.

MYSQL_HOST=127.0.0.1
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=hidrs_db

# Windows: 5000 is often reserved; app defaults to 5001 on win32 if PORT is unset
PORT=5001
FALCON_SECRET_KEY=change_this_in_production

# Set to 1 / true / yes to disable self-service registration (login still works)
# FALCON_DISABLE_SIGNUP=0
